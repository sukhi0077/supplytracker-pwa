# Copy this file to `.env` and fill in your Supabase project values.
#
# IMPORTANT: use the SAME Supabase project as order-stock-pwa. Both apps share
# one database. Get these from: Supabase Dashboard -> Project Settings -> API.
#
# BOTH must be prefixed with VITE_ so Vite exposes them to the frontend.
#
# VITE_SUPABASE_PUBLISHABLE_KEY is the PUBLIC publishable key (sb_publishable_...).
# It is safe to ship *because* Row-Level Security is on. NEVER put a secret key
# (sb_secret_... / service_role) in the frontend or in git — that stays server-
# side (e.g. in the Cloudflare Worker for KSeF/wFirma).
#
# In production, set these same two vars in:
#   Cloudflare Pages -> your project -> Settings -> Environment variables.


VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: URL of the deployed Cloudflare Worker that runs KSeF fetch / wFirma
# sync. Used by the "Download KSeF" page for on-demand runs. Leave blank until
# the Worker (see workers/) is deployed — fetch also runs automatically on cron.
VITE_KSEF_WORKER_URL=
